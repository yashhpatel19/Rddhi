# Production Environment Configuration Template
# DO NOT COMMIT THIS FILE - Use environment variables instead
# This is a template for values you need to set in your hosting platform

# === DEPLOYMENT ENVIRONMENT ===
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# === APPLICATION CONFIG ===
API_HOST=0.0.0.0
API_PORT=8000
REACT_APP_ENVIRONMENT=production

# === SECURITY KEYS (GENERATE NEW ONES - NEVER USE DEVELOPMENT KEYS) ===
# Generate ENCRYPTION_KEY: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=YOUR_NEW_ENCRYPTION_KEY_HERE

# Generate JWT_SECRET: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=YOUR_NEW_JWT_SECRET_HERE

# === DATABASE ===
# Use MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/rddhi?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://username:password@your-cluster.mongodb.net/rddhi?retryWrites=true&w=majority
DB_NAME=rddhi

# === JWT CONFIGURATION ===
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# === CORS (Set to your production domain) ===
CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# === RATE LIMITING ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# === FRONTEND ===
REACT_APP_BACKEND_URL=https://api.yourdomain.com

# === EMAIL/NOTIFICATIONS (Optional for alerts) ===
ADMIN_EMAIL=your-email@company.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# === BACKUP CONFIGURATION ===
BACKUP_ENABLED=true
BACKUP_FREQUENCY_HOURS=24
BACKUP_RETENTION_DAYS=30
