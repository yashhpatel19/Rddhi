#!/bin/bash
# Pre-commit hook to prevent committing secrets
# Install: cp scripts/pre-commit-hook .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Counters
ERRORS=0
WARNINGS=0

# Get staged files
STAGED_FILES=$(git diff --cached --name-only)

echo "🔐 Running pre-commit security checks..."

# Check for .env files
if echo "$STAGED_FILES" | grep -E "\.env($|\.)" > /dev/null; then
    echo -e "${RED}✗ ERROR: .env file staged for commit!${NC}"
    echo "  .env files must never be committed to git"
    echo "  Use: git reset HEAD <filename>"
    ((ERRORS++))
fi

# Check for common secret patterns in staged files
PATTERN_CHECKS=(
    "ENCRYPTION_KEY="
    "JWT_SECRET="
    "MONGO_URL=.*:.*@.*:.*"
    "DATABASE_PASSWORD="
    "API_KEY="
    "SECRET="
    "password:"
    "private_key"
    "-----BEGIN PRIVATE KEY-----"
    "-----BEGIN RSA PRIVATE KEY-----"
)

for file in $STAGED_FILES; do
    # Skip binary files
    if file "$file" | grep -q "binary"; then
        continue
    fi
    
    # Skip .example files (they should have placeholders)
    if [[ "$file" == *".example"* ]]; then
        continue
    fi
    
    # Check each pattern
    for pattern in "${PATTERN_CHECKS[@]}"; do
        if git diff --cached "$file" | grep -i "$pattern" > /dev/null 2>&1; then
            echo -e "${YELLOW}⚠ WARNING: Potential secret detected in $file${NC}"
            echo "  Pattern: $pattern"
            echo "  Use: git reset HEAD $file"
            echo "  Then audit and remove the secret"
            ((WARNINGS++))
        fi
    done
done

# Check file permissions (warn if .env exists with bad permissions)
if [ -f "backend/.env" ] && [ "$(stat -c %a backend/.env 2>/dev/null || stat -f %A backend/.env 2>/dev/null)" != "600" ]; then
    echo -e "${YELLOW}⚠ WARNING: backend/.env has permissive permissions${NC}"
    echo "  Fix with: chmod 600 backend/.env"
    ((WARNINGS++))
fi

if [ -f "frontend/.env" ] && [ "$(stat -c %a frontend/.env 2>/dev/null || stat -f %A frontend/.env 2>/dev/null)" != "600" ]; then
    echo -e "${YELLOW}⚠ WARNING: frontend/.env has permissive permissions${NC}"
    echo "  Fix with: chmod 600 frontend/.env"
    ((WARNINGS++))
fi

# Summary
echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}❌ Commit BLOCKED: $ERRORS critical security issue(s) found${NC}"
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠ $WARNINGS warning(s) - review before committing${NC}"
    read -p "Continue anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
else
    echo -e "${GREEN}✓ No secrets detected - safe to commit${NC}"
fi

exit 0
