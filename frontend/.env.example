# =============================================================
# FRONTEND ENVIRONMENT VARIABLES - Copy to .env and fill values
# =============================================================

# ============ BACKEND API CONFIGURATION ============
# Backend API URL - no trailing slash
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
REACT_APP_BACKEND_URL=http://localhost:8000

# ============ ENVIRONMENT ============
# Environment: development, staging, production
REACT_APP_ENVIRONMENT=development

# ============ OPTIONAL: ANALYTICS & MONITORING ============
# Google Analytics ID (optional)
REACT_APP_GA_ID=

# Sentry DSN for error tracking (optional)
REACT_APP_SENTRY_DSN=

# Feature flags (optional)
REACT_APP_ENABLE_ADVANCED_CHARTS=true
REACT_APP_ENABLE_EXPORTS=true

# ============ DEPLOYMENT CHECKS ============
# Make sure to fill:
# - REACT_APP_BACKEND_URL (update for production domain)
# - REACT_APP_ENVIRONMENT (set to 'production' for live deployment)

# Note: React will inject these at build time
# Prefix all vars with REACT_APP_ so they're available in the browser
